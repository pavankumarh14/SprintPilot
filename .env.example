# Frontend
REACT_APP_API_URL=http://localhost:8000

# Backend — all optional; omit to run in mock/demo mode
PORT=8000

# LLM keys (optional — enable real AI estimates & digests)
# Provide ONE of the following:
OPENAI_API_KEY=sk-...          # uses gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-...   # uses claude-haiku
#
# Alternatively, enter your key in the browser under Settings → LLM API Key
# (stored in browser localStorage, sent per-request via X-LLM-Key header)

# Notifications (optional — required only when notifier stubs are implemented)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...   # Slack Incoming Webhook URL
SLACK_BOT_TOKEN=xoxb-...                                  # Slack Bot Token (for interactive features)
SENDGRID_API_KEY=SG....                                   # SendGrid API key for email
ALERT_TO_EMAIL=team@example.com                           # recipient email for digest alerts

# Jira Cloud integration (optional — pull real tickets and sprint history)
JIRA_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=ATATT3...                                  # https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_PROJECT_KEY=PROJ
JIRA_BOARD_ID=1                                           # Agile board ID (integer)

# GitHub integration (optional — pull issues as backlog tickets)
GITHUB_TOKEN=ghp_...                                      # Personal Access Token with repo:read scope
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo

# Linear integration (optional — pull issues from Linear)
LINEAR_API_KEY=lin_api_...                                # https://linear.app/settings/api
LINEAR_TEAM_ID=TEAM_ID
